{
  "$schema": "https://opencode.ai/config.json",
  "shell": "/bin/zsh",
  "mcp": {
    "playwright": {
      "type": "local",
      "command": ["npx", "-y", "@playwright/mcp"],
      "enabled": true
    },
    "github": {
      "type": "remote",
      "url": "https://api.github.com",
      "headers": { "Authorization": "Bearer ${GITHUB_TOKEN}" },
      "enabled": true
    },
    "filesystem": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-filesystem", "/home/optroot/projects"],
      "enabled": true
    },
    "web-search": {
      "type": "local",
      "command": ["npx", "-y", "@anthropic/mcp-server-web-search"],
      "enabled": true,
      "env": { "TAVILY_API_KEY": "${TAVILY_API_KEY}" }
    },
    "fetch": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-fetch"],
      "enabled": true
    },
    "memory": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-memory"],
      "enabled": true
    },
    "code-search": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-sourcegraph"],
      "enabled": true,
      "env": { "SOURCEGRAPH_API_TOKEN": "${SOURCEGRAPH_API_TOKEN}" }
    },
    "aws": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-aws-kb"],
      "enabled": true,
      "env": { "AWS_REGION": "${AWS_REGION}" }
    }
  }
}
