#!/bin/bash
# Project switcher - navigates ~/projects/{category}/{project}
# Usage: p <name>        # fuzzy find and cd to project
#        p -l            # list all projects
#        p -t            # list projects with taskwarrior tasks

set -euo pipefail

PROJECTS_DIR="$HOME/projects"

_list_projects() {
  find "$PROJECTS_DIR" -mindepth 2 -maxdepth 2 -type d | sort
}

_find_project() {
  local query="$1"
  _list_projects | while IFS= read -r dir; do
    basename "$dir"
  done | fzf --filter="$query" | head -1
}

_goto_project() {
  local name="$1"
  local dir
  dir="$(_list_projects | while IFS= read -r d; do
    [ "$(basename "$d")" = "$name" ] && echo "$d" && break
  done)"
  if [ -n "$dir" ]; then
    cd "$dir"
    exec "$SHELL"
  else
    echo "No project found: $name" >&2
    return 1
  fi
}

case "${1:-}" in
  -l)
    _list_projects | while IFS= read -r dir; do
      printf "%-30s %s\n" "$(basename "$dir")" "${dir#$PROJECTS_DIR/}"
    done
    ;;
  -t)
    _list_projects | while IFS= read -r dir; do
      name="$(basename "$dir")"
      count=$(task project:"$name" count 2>/dev/null || echo 0)
      [ "$count" -gt 0 ] && printf "%-30s %d tasks\n" "$name" "$count"
    done
    ;;
  "")
    dir=$(cd "$PROJECTS_DIR" && _list_projects | while IFS= read -r d; do
      echo "$(basename "$d")|$d"
    done | fzf --with-nth=1 --delimiter="|" --preview="ls -la {2}" | cut -d"|" -f2)
    if [ -n "$dir" ]; then
      cd "$dir"
      exec "$SHELL"
    fi
    ;;
  *)
    _goto_project "$1"
    ;;
esac
